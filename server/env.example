# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/kalasetu"

# ── Server ────────────────────────────────────────────────
PORT=5000
# Comma-separated allowed origins in production. In dev, any origin is allowed (LAN-friendly).
FRONTEND_URL="http://localhost:3000"

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-too"
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Razorpay (server-side ONLY — never expose KEY_SECRET to frontend) ──
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."

# ── Cloudinary (optional — image uploads) ─────────────────
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# ── Redis (optional — caching / sessions) ─────────────────
REDIS_URL=redis://localhost:6379
